{
    "name": "convoy.js",
    "version": "2.0.0-alpha.0",
    "description": "Convoy JS SDK (Speakeasy-generated API client; hand-written webhook verify)",
    "main": "dist/convoy.js",
    "scripts": {
        "test": "jest --config jestconfig.json",
        "prepare": "npm run build",
        "build": "tsc",
        "format": "prettier --write \"src/**/*.ts\"",
        "lint": "tslint -p tsconfig.json",
        "test:verify": "jest --config jestconfig.json --testPathPattern='(webhook|shared-vectors)'"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/frain-dev/convoy.js"
    },
    "keywords": [
        "convoy",
        "webhooks"
    ],
    "author": "Convoy",
    "license": "MIT",
    "dependencies": {},
    "files": [
        "dist/**/*"
    ],
    "devDependencies": {
        "@types/jest": "^29.5.8",
        "@types/node": "^20.9.0",
        "jest": "^29.7.0",
        "prettier": "^3.1.0",
        "ts-jest": "^29.1.1",
        "tslint-config-prettier": "^1.18.0",
        "typescript": "^5.2.2"
    }
}
